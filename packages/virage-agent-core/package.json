{
  "name": "@vivantel/virage-agent-core",
  "version": "0.1.4",
  "description": "Shared base types and abstract class for Virage agent plugins — universal hook event model for Claude Code, GitHub Copilot, OpenAI Codex, and Google Antigravity",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vivantel/virage",
    "directory": "packages/virage-agent-core"
  },
  "keywords": [
    "rag",
    "agent",
    "hooks",
    "claude",
    "copilot",
    "codex",
    "antigravity",
    "virage"
  ],
  "author": "Vivantel",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "npm run build && npm test",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "fix": "npm run lint:fix && npm run format"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
