{
  "name": "@vivantel/virage-embedder-openai",
  "version": "0.3.10",
  "description": "OpenAI-compatible embedding provider for @vivantel/rag-core",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "fix": "npm run lint:fix && npm run format"
  },
  "keywords": [
    "rag",
    "embeddings",
    "openai",
    "azure"
  ],
  "author": "Vivantel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vivantel/virage",
    "directory": "packages/virage-embedder-openai"
  },
  "dependencies": {
    "openai": "^6.45.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@vivantel/virage-core": "*"
  },
  "devDependencies": {
    "@vivantel/virage-core": "0.4.10",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
