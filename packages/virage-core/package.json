{
  "name": "@vivantel/virage-core",
  "version": "0.2.2",
  "type": "module",
  "description": "Core RAG pipeline tools - universal chunking, embedding, vector store interfaces",
  "repository": {
    "type": "git",
    "url": "https://github.com/vivantel/virage",
    "directory": "packages/virage-core"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "virage": "./dist/bin/virage.js"
  },
  "files": [
    "dist",
    "schemas",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && echo \"✅ Build completed successfully\"",
    "dev": "tsx watch src/index.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "fix": "npm run lint:fix && npm run format",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest watch --config vitest.config.ts",
    "test:coverage": "vitest --coverage --config vitest.config.ts",
    "test:acceptance": "npm run build -w @vivantel/virage-store-test && npm run build && vitest run --config vitest.acceptance.config.ts",
    "prepublishOnly": "npm run build && npm test",
    "docs:generate": "typedoc"
  },
  "keywords": [
    "rag",
    "embeddings",
    "vector",
    "git",
    "pipeline"
  ],
  "author": "Vivantel",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "consola": "^3.4.2",
    "dotenv": "^17.4.2",
    "glob": "^13.0.6",
    "simple-git": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@supabase/supabase-js": "^2.106.2",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
