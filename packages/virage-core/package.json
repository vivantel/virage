{
  "name": "@vivantel/virage-core",
  "version": "0.4.8",
  "type": "module",
  "description": "Core RAG pipeline tools - universal chunking, embedding, vector store interfaces",
  "repository": {
    "type": "git",
    "url": "https://github.com/vivantel/virage",
    "directory": "packages/virage-core"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "schemas",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && tsc && echo \"✅ Build completed successfully\"",
    "dev": "tsx watch src/index.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "fix": "npm run lint:fix && npm run format",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest watch --config vitest.config.ts",
    "test:coverage": "vitest --coverage --config vitest.config.ts",
    "test:acceptance": "npm run build -w @vivantel/virage-store-test && npm run build && vitest run --config vitest.acceptance.config.ts",
    "prepublishOnly": "npm run build && npm test",
    "docs:generate": "typedoc"
  },
  "keywords": [
    "rag",
    "embeddings",
    "vector",
    "git",
    "pipeline"
  ],
  "author": "Vivantel",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "glob": "^13.0.6",
    "minimatch": "^10.0.0",
    "simple-git": "^3.25.0",
    "tar": "^7.5.19",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@supabase/supabase-js": "^2.110.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "rimraf": "^6.0.1",
    "tsx": "^4.23.0",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
