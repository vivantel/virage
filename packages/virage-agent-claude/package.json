{
  "name": "@vivantel/virage-agent-claude",
  "version": "0.2.8",
  "description": "Claude Code agent plugin for Virage — installs skills and configures Claude Code hooks and MCP server",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "virage-agent-claude": "./dist/cli.js"
  },
  "files": [
    "dist",
    "plugin-config",
    "README.md"
  ],
  "virage-agent": {
    "name": "claude-code",
    "label": "Claude Code",
    "configure": "./dist/plugin.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vivantel/virage",
    "directory": "packages/virage-agent-claude"
  },
  "keywords": [
    "rag",
    "mcp",
    "model-context-protocol",
    "claude",
    "agent",
    "skills",
    "virage"
  ],
  "author": "Vivantel",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "rimraf dist && tsc && chmod +x dist/cli.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "npm run build && npm test",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "fix": "npm run lint:fix && npm run format"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@vivantel/virage-agent-core": "0.1.4",
    "@vivantel/virage-skills": "0.1.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
