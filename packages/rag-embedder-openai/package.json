{
  "name": "@vivantel/rag-embedder-openai",
  "version": "1.4.6",
  "description": "OpenAI-compatible embedding provider for @vivantel/rag-core",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "fix": "npm run lint:fix && npm run format"
  },
  "keywords": [
    "rag",
    "embeddings",
    "openai",
    "azure",
    "github-models"
  ],
  "author": "Vivantel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vivantel/rag_core",
    "directory": "packages/rag-embedder-openai"
  },
  "dependencies": {
    "openai": "^6.41.0"
  },
  "peerDependencies": {
    "@vivantel/rag-core": "^2.0.0"
  },
  "devDependencies": {
    "@vivantel/rag-core": "file:../rag-core",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
