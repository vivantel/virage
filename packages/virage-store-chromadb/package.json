{
  "name": "@vivantel/virage-store-chromadb",
  "version": "0.2.51",
  "description": "ChromaDB vector store for @vivantel/rag-core (local or hosted)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "rag-plugin": {
    "type": "vectorStore",
    "label": "ChromaDB (local or hosted)",
    "key": "chromadb",
    "envVars": [],
    "defaultConfig": {
      "path": "http://localhost:8000"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "fix": "npm run lint:fix && npm run format"
  },
  "keywords": [
    "rag",
    "vector-store",
    "chromadb",
    "vector-database",
    "semantic-search"
  ],
  "author": "Vivantel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vivantel/virage",
    "directory": "packages/virage-store-chromadb"
  },
  "dependencies": {
    "chromadb": "^3.4.3",
    "minisearch": "^7.0.0"
  },
  "peerDependencies": {
    "@vivantel/virage-core": "*"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@vivantel/virage-core": "0.2.49",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
