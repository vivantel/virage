{
  "name": "@vivantel/virage-reranker-cross-encoder",
  "version": "0.1.20",
  "description": "Local cross-encoder re-ranker for Virage (ONNX, no API key required)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "rag",
    "reranker",
    "cross-encoder",
    "onnx",
    "local"
  ],
  "author": "Vivantel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vivantel/virage",
    "directory": "packages/virage-reranker-cross-encoder"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.0.0"
  },
  "peerDependencies": {
    "@vivantel/virage-core": "*"
  },
  "devDependencies": {
    "@vivantel/virage-core": "0.2.42",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
