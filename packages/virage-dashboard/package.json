{
  "name": "@vivantel/virage-dashboard",
  "version": "0.1.25",
  "type": "module",
  "description": "React dashboard web app for the Virage RAG pipeline — served by virage-cli",
  "author": "Vivantel",
  "license": "MIT",
  "keywords": [
    "rag",
    "dashboard",
    "monitoring",
    "react",
    "pipeline"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vivantel/virage",
    "directory": "packages/virage-dashboard"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "fix": "npm run lint:fix && npm run format",
    "test:e2e": "playwright test",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "react-virtuoso": "^4.18.9",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
