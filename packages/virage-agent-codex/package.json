{
  "name": "@vivantel/virage-agent-codex",
  "version": "0.1.11",
  "description": "OpenAI Codex agent plugin for Virage — configures Codex hooks from virage-skills",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "virage-agent": {
    "name": "codex",
    "label": "OpenAI Codex",
    "configure": "./dist/plugin.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vivantel/virage",
    "directory": "packages/virage-agent-codex"
  },
  "keywords": [
    "rag",
    "agent",
    "hooks",
    "codex",
    "openai",
    "virage"
  ],
  "author": "Vivantel",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "npm run build && npm test",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "fix": "npm run lint:fix && npm run format"
  },
  "dependencies": {
    "@vivantel/virage-agent-core": "0.1.8",
    "@vivantel/virage-skills": "0.1.9"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
