{
  "name": "@vivantel/virage-mcp",
  "version": "0.1.1",
  "type": "module",
  "description": "MCP stdio server for Virage RAG — search and inspect your index from AI assistants",
  "author": "Vivantel",
  "license": "MIT",
  "keywords": [
    "rag",
    "mcp",
    "model-context-protocol",
    "embeddings",
    "search",
    "virage"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vivantel/virage",
    "directory": "packages/virage-mcp"
  },
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "virage-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "fix": "npm run lint:fix && npm run format"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0",
    "@vivantel/virage-core": "0.2.11"
  },
  "peerDependencies": {
    "@vivantel/virage-core": "*"
  },
  "devDependencies": {
    "@vivantel/virage-core": "0.2.11",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
