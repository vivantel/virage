{
  "name": "@vivantel/virage-cli",
  "version": "0.1.84",
  "type": "module",
  "description": "CLI for the Virage RAG pipeline — provides the virage command",
  "repository": {
    "type": "git",
    "url": "https://github.com/vivantel/virage",
    "directory": "packages/virage-cli"
  },
  "main": "dist/bin/virage.js",
  "exports": {
    ".": {
      "import": "./dist/bin/virage.js",
      "types": "./dist/bin/virage.d.ts"
    }
  },
  "bin": {
    "virage": "./dist/bin/virage.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && tsc && chmod +x dist/bin/virage.js && cp -r ../virage-dashboard/dist dist/dashboard-ui 2>/dev/null || true && echo \"✅ Build completed successfully\"",
    "build:with-dashboard": "npm run build -w @vivantel/virage-dashboard && npm run build",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "fix": "npm run lint:fix && npm run format",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest watch --config vitest.config.ts",
    "test:coverage": "vitest --coverage --config vitest.config.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "rag",
    "embeddings",
    "cli",
    "vector",
    "pipeline"
  ],
  "author": "Vivantel",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@vivantel/virage-agent-claude": "0.2.26",
    "@vivantel/virage-core": "0.2.53",
    "@vivantel/virage-skills": "0.1.9",
    "chokidar": "^5.0.0",
    "cli-progress": "^3.12.0",
    "commander": "^15.0.0",
    "consola": "^3.4.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "glob": "^13.0.6",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cli-progress": "^3.11.6",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "rimraf": "^6.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
