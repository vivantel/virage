{
  "release-type": "node",
  "auto-merge": true,
  "separate-pull-requests": false,
  "include-component-in-tag": true,
  "tag-separator": "@",
  "packages": {
    "packages/virage-core": {
      "package-name": "@vivantel/virage-core",
      "changelog-path": "CHANGELOG.md",
      "release-type": "node",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "draft": false,
      "prerelease": false
    },
    "packages/virage-strategies": {
      "package-name": "@vivantel/virage-strategies",
      "changelog-path": "CHANGELOG.md",
      "release-type": "node",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "draft": false,
      "prerelease": false
    },
    "packages/virage-embedder-openai": {
      "package-name": "@vivantel/virage-embedder-openai",
      "changelog-path": "CHANGELOG.md",
      "release-type": "node",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "draft": false,
      "prerelease": false
    },
    "packages/virage-embedder-transformers": {
      "package-name": "@vivantel/virage-embedder-transformers",
      "changelog-path": "CHANGELOG.md",
      "release-type": "node",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "draft": false,
      "prerelease": false
    },
    "packages/virage-embedder-fastembed": {
      "package-name": "@vivantel/virage-embedder-fastembed",
      "changelog-path": "CHANGELOG.md",
      "release-type": "node",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "draft": false,
      "prerelease": false
    },
    "packages/virage-store-postgres": {
      "package-name": "@vivantel/virage-store-postgres",
      "changelog-path": "CHANGELOG.md",
      "release-type": "node",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "draft": false,
      "prerelease": false
    },
    "packages/virage-store-qdrant": {
      "package-name": "@vivantel/virage-store-qdrant",
      "changelog-path": "CHANGELOG.md",
      "release-type": "node",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "draft": false,
      "prerelease": false
    },
    "packages/virage-store-lancedb": {
      "package-name": "@vivantel/virage-store-lancedb",
      "changelog-path": "CHANGELOG.md",
      "release-type": "node",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "draft": false,
      "prerelease": false
    },
    "packages/virage-store-chromadb": {
      "package-name": "@vivantel/virage-store-chromadb",
      "changelog-path": "CHANGELOG.md",
      "release-type": "node",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "draft": false,
      "prerelease": false
    }
  },
  "plugins": [
    {
      "type": "node-workspace",
      "merge": false
    },
    {
      "type": "sentence-case",
      "pull-request-title-pattern": "chore: release ${version}"
    }
  ],
  "changelog-sections": [
    {"type": "feat", "section": "Features", "hidden": false},
    {"type": "fix", "section": "Bug Fixes", "hidden": false},
    {"type": "perf", "section": "Performance Improvements", "hidden": false},
    {"type": "refactor", "section": "Code Refactoring", "hidden": false},
    {"type": "docs", "section": "Documentation", "hidden": false},
    {"type": "style", "section": "Styles", "hidden": true},
    {"type": "test", "section": "Tests", "hidden": true},
    {"type": "chore", "section": "Miscellaneous Chores", "hidden": true}
  ]
}