#!/usr/bin/env bash
# Abort push if native platform-stub versions in package-lock.json are out of sync
# with their optionalDependency pins in package.json.
# Also checks that each native package compiles cleanly with its production feature set.

set -euo pipefail

# Patch native platform-stub version fields. If anything changed, the lockfile
# is out of sync and must be committed before pushing.
# We do NOT run `npm install --package-lock-only` here — that rewrites cosmetic
# key ordering across the whole file and triggers false positives every push.
node scripts/patch-lockfile-stubs.cjs 2>/dev/null || true

if ! git diff --quiet package-lock.json; then
  echo ""
  echo "pre-push: package-lock.json stub versions are out of sync with package.json."
  echo "  Run: node scripts/patch-lockfile-stubs.cjs"
  echo "  Then: git add package-lock.json && git commit -m 'chore: sync package-lock.json'"
  echo ""
  # Restore to HEAD so the working tree stays clean
  git checkout package-lock.json
  exit 1
fi

# Check production feature sets for native packages.
# Add a line here whenever a native package uses non-default production flags.
prod_checks=(
  "virage-embedder-onnx|--no-default-features --features download-binaries"
)
for entry in "${prod_checks[@]}"; do
  pkg="${entry%%|*}"
  flags="${entry##*|}"
  if git diff --name-only HEAD@{1} HEAD 2>/dev/null | grep -q "packages/$pkg/\|Cargo"; then
    echo "pre-push: checking $pkg production features ($flags)..."
    if ! cargo check -p "$pkg" $flags --quiet 2>&1; then
      echo ""
      echo "pre-push: $pkg fails to compile with production flags: $flags"
      echo "  Fix the Rust code or feature definitions before pushing."
      echo ""
      exit 1
    fi
  fi
done
