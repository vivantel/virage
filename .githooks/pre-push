#!/usr/bin/env bash
# Abort push if package-lock.json is out of sync with package.json files.
# Catches the case where a developer bumped a version locally without running npm install.
# Also checks that native packages compile with their production feature sets.

set -euo pipefail

# Regenerate lockfile metadata and patch stub versions, then check for drift.
# The committed lockfile is kept canonical by native-publish.yaml post-publish,
# so this only fires when there is genuine local drift.
npm install --package-lock-only --ignore-scripts --silent 2>/dev/null
node scripts/patch-lockfile-stubs.cjs 2>/dev/null || true

if ! git diff --quiet package-lock.json; then
  echo ""
  echo "pre-push: package-lock.json is out of sync with package.json."
  echo "  Run: npm install --ignore-scripts && git add package-lock.json && git commit -m 'chore: sync package-lock.json'"
  echo ""
  git checkout package-lock.json
  exit 1
fi

# Check production feature sets for native packages.
# Add a line here whenever a native package uses non-default production flags.
prod_checks=(
  "virage-embedder-onnx|--no-default-features --features download-binaries"
)
for entry in "${prod_checks[@]}"; do
  pkg="${entry%%|*}"
  flags="${entry##*|}"
  if git diff --name-only HEAD@{1} HEAD 2>/dev/null | grep -q "packages/$pkg/\|Cargo"; then
    echo "pre-push: checking $pkg production features ($flags)..."
    cargo check -p "$pkg" $flags --quiet || {
      echo ""
      echo "pre-push: $pkg fails to compile with production flags: $flags"
      echo "  Fix the Rust code or feature definitions before pushing."
      echo ""
      exit 1
    }
  fi
done
