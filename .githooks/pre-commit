#!/usr/bin/env bash
# Minimal CE pre-commit: formatting only.
# Scoped clippy for EE-side Claude Code sessions lives in virage-ee/.claude/settings.json.
set -euo pipefail

if ! cargo fmt --check 2>/dev/null; then
  echo ""
  echo "pre-commit: Rust formatting issues found."
  echo "  Run: cargo fmt && git add -u"
  echo ""
  exit 1
fi
