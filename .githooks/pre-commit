#!/usr/bin/env bash
# Block commits with unformatted Rust code or clippy errors.
# Catches direct `git commit` invocations outside Claude Code.
# (Claude Code's PreToolUse hook auto-fixes with `cargo fmt` and runs clippy before any commit.)
set -euo pipefail

if ! cargo fmt --check 2>/dev/null; then
  echo ""
  echo "pre-commit: Rust formatting issues found."
  echo "  Run: cargo fmt && git add -u"
  echo ""
  exit 1
fi

cargo clippy --workspace -- -D warnings || {
  echo ""
  echo "pre-commit: Rust clippy errors found."
  echo "  Run: cargo clippy --workspace -- -D warnings"
  echo ""
  exit 1
}
