{
  "$schema": "https://unpkg.com/@vivantel/virage-core/schemas/virage.config.schema.json",
  "chunking": {
    "exclude": [
      "**/*.a",
      "**/*.class",
      "**/*.generated.cs",
      "**/*.lock",
      "**/*.min.css",
      "**/*.min.js",
      "**/*.o",
      "**/*.pb.cs",
      "**/*.pb.go",
      "**/*.pb.ts",
      "**/.next/**",
      "**/.turbo/**",
      "**/CMakeFiles/**",
      "**/bin/**",
      "**/cmake-build-*/**",
      "**/dist/**",
      "**/node_modules/**",
      "**/obj/**",
      "**/out/**",
      "**/package-lock.json",
      "**/pnpm-lock.yaml",
      "**/target/**",
      "**/vendor/**",
      "**/yarn.lock"
    ],
    "chunkers": [
      {
        "package": "@vivantel/virage-chunker-ce-md"
      },
      {
        "package": "@vivantel/virage-code-chunk-chunker",
        "include": ["**/*.ts", "**/*.tsx"]
      },
      {
        "package": "@vivantel/virage-code-chunk-chunker",
        "include": ["**/*.js", "**/*.jsx"]
      }
    ]
  },
  "agents": [],
  "embedder": {
    "package": "@vivantel/virage-embedder-transformers",
    "config": {
      "model": "Xenova/all-MiniLM-L6-v2",
      "dimensions": 384
    }
  },
  "vectorStore": {
    "package": "@vivantel/virage-store-lancedb",
    "config": {
      "uri": ".virage/lancedb"
    }
  },
  "search": {
    "reranker": {
      "package": "@vivantel/virage-reranker-cross-encoder",
      "config": {
        "model": "Xenova/ms-marco-MiniLM-L-6-v2",
        "topK": 5
      }
    },
    "hybrid": true,
    "hybridAlpha": 0.6
  },
  "pluginVersions": {
    "@vivantel/virage-embedder-transformers": "latest",
    "@vivantel/virage-store-lancedb": "latest",
    "@vivantel/virage-chunker-ce-md": "latest",
    "@vivantel/virage-code-chunk-chunker": "latest",
    "@vivantel/virage-reranker-cross-encoder": "latest"
  },
  "installScope": "local"
}
