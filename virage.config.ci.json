{
  "providers": {
    "embedder": {
      "builtin": "onnx",
      "options": {
        "source": { "model": "Xenova/all-MiniLM-L6-v2", "cacheDir": ".virage/model-cache" },
        "dimensions": 384
      }
    },
    "vectorStore": {
      "builtin": "lancedb",
      "options": { "uri": ".virage/lancedb" }
    },
    "reranker": {
      "builtin": "cross-encoder",
      "options": {
        "source": { "model": "Xenova/ms-marco-MiniLM-L-6-v2", "cacheDir": ".virage/model-cache" }
      }
    }
  },
  "fileSets": [
    {
      "name": "markdown",
      "include": ["**/*.md"],
      "ignore": ["CHANGELOG.md", "**/CHANGELOG.md"],
      "chunkers": [{ "builtin": "md" }]
    },
    {
      "name": "typescript",
      "include": ["packages/*/src/**/*.ts"],
      "ignore": ["**/*.test.ts", "**/*.spec.ts", "**/*.d.ts"],
      "tags": ["lang:typescript"],
      "chunkers": [{ "builtin": "lang" }]
    }
  ],
  "ignore": ["**/node_modules/**", "**/dist/**", "**/target/**"],
  "search": { "minSimilarity": 0.55 }
}
