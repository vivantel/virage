{
  "$schema": "./packages/virage-core/schemas/virage.config.schema.json",
  "providers": {
    "embedder": {
      "package": "@vivantel/virage-embedder-onnx",
      "options": {
        "model": "Xenova/all-MiniLM-L6-v2",
        "dimensions": 384,
        "cacheDir": ".virage/model-cache"
      }
    },
    "vectorStore": {
      "package": "@vivantel/virage-store-lancedb",
      "options": {
        "uri": ".virage/lancedb"
      }
    },
    "reranker": {
      "package": "@vivantel/virage-reranker-cross-encoder",
      "options": {
        "model": "Xenova/ms-marco-MiniLM-L-6-v2",
        "cacheDir": ".virage/model-cache"
      }
    }
  },
  "fileSets": [
    {
      "name": "markdown",
      "include": ["**/*.md"],
      "ignore": ["CHANGELOG.md", "**/CHANGELOG.md"],
      "chunkers": [
        { "package": "@vivantel/virage-chunker-ce-md" }
      ]
    }
  ],
  "ignore": ["**/node_modules/**", "**/dist/**", "**/target/**"],
  "search": {
    "minSimilarity": 0.55
  }
}
