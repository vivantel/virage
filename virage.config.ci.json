{
  "$schema": "./packages/virage-core/schemas/virage.config.schema.json",
  "chunkers": [
    {
      "patterns": ["**/*.md", "**/*.mdx"],
      "strategy": "markdownHeaders",
      "ignorePatterns": ["**/node_modules/**", "CHANGELOG.md"]
    },
    {
      "patterns": ["packages/**/*.ts"],
      "strategy": "token",
      "ignorePatterns": ["**/*.test.ts", "**/*.d.ts", "**/dist/**"]
    },
    {
      "patterns": ["**/*.yaml", "**/*.yml"],
      "strategy": "wholeFile",
      "ignorePatterns": ["**/node_modules/**"]
    }
  ],
  "embedder": {
    "package": "@vivantel/virage-embedder-transformers",
    "config": {
      "model": "Xenova/all-MiniLM-L6-v2",
      "dimensions": 384,
      "cacheDir": ".virage/model-cache"
    }
  },
  "vectorStore": {
    "package": "@vivantel/virage-store-lancedb",
    "config": {
      "uri": ".virage/lancedb",
      "dimensions": 384
    }
  }
}
