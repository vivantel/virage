{
  "$schema": "./packages/virage-core/schemas/virage.config.schema.json",
  "chunking": {
    "chunkers": [
      {
        "package": "@vivantel/virage-chunker-ce-md",
        "version": "^0.1.3",
        "options": {
          "ignore": ["**/node_modules/**", "CHANGELOG.md"]
        }
      },
      {
        "package": "@vivantel/virage-chunker-ce-ts",
        "version": "^0.1.0",
        "options": {
          "ignore": ["**/*.test.ts", "**/*.d.ts", "**/dist/**", "**/node_modules/**"]
        }
      }
    ]
  },
  "embedder": {
    "package": "@vivantel/virage-embedder-transformers",
    "config": {
      "model": "Xenova/all-MiniLM-L6-v2",
      "dimensions": 384,
      "cacheDir": ".virage/model-cache"
    }
  },
  "vectorStore": {
    "package": "@vivantel/virage-store-lancedb",
    "config": {
      "uri": ".virage/lancedb",
      "dimensions": 384
    }
  }
}
