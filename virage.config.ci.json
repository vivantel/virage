{
  "providers": {
    "embedder": {
      "builtin": "onnx",
      "options": {
        "model": "Xenova/all-MiniLM-L6-v2",
        "dimensions": 384,
        "cacheDir": ".virage/model-cache"
      }
    },
    "vectorStore": {
      "builtin": "lancedb",
      "options": {
        "uri": ".virage/lancedb"
      }
    }
  },
  "fileSets": [
    {
      "name": "markdown",
      "include": ["**/*.md"],
      "ignore": ["CHANGELOG.md", "**/CHANGELOG.md"],
      "chunkers": [
        { "builtin": "md" }
      ]
    },
    {
      "name": "typescript",
      "include": ["packages/*/src/**/*.ts"],
      "ignore": ["**/*.test.ts", "**/*.spec.ts", "**/*.d.ts"],
      "tags": ["lang:typescript"],
      "chunkers": [
        { "builtin": "lang" }
      ]
    }
  ],
  "ignore": ["**/node_modules/**", "**/dist/**", "**/target/**"],
  "search": {
    "minSimilarity": 0.55
  }
}
