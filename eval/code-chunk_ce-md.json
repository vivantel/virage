    "**/*.a",
    "**/*.class",
    "**/*.generated.cs",
    "**/*.lock",
    "**/*.min.css",
    "**/*.min.js",
    "**/*.o",
    "**/*.pb.cs",
    "**/*.pb.go",
    "**/*.pb.ts",
    "**/.next/**",
    "**/.turbo/**",
    "**/CMakeFiles/**",
    "**/bin/**",
