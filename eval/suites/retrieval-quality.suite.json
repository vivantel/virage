{
  "version": "1",
  "dataset": "../quality-evaluation.ds.json",
  "topK": 10,
  "baseline": "vector",
  "ciGate": {
    "mrr": 0.35
  },
  "cacheDir": "../../.virage/eval-cache",
  "exclude": [
    "**/*.a",
    "**/*.class",
    "**/*.generated.cs",
    "**/*.lock",
    "**/*.min.css",
    "**/*.min.js",
    "**/*.o",
    "**/*.pb.cs",
    "**/*.pb.go",
    "**/*.pb.ts",
    "**/.next/**",
    "**/.turbo/**",
    "**/CMakeFiles/**",
    "**/bin/**",
    "**/cmake-build-*/**",
    "**/package-lock.json",
    "**/pnpm-lock.yaml",
    "**/target/**",
    "**/yarn.lock"
  ],
  "filesets": {
    "md": {
      "include": [
        "**/*.md",
        "**/*.mdx"
      ],
      "exclude": [
        "**/node_modules/**",
        "**/vendor/**",
        "**/dist/**",
        "**/out/**",
        "CHANGELOG.md"
      ]
    },
    "ts": {
      "include": [
        "**/*.ts",
        "**/*.tsx"
      ],
      "exclude": [
        "**/node_modules/**",
        "**/vendor/**",
        "**/dist/**",
        "**/out/**",
        "**/*.d.ts"
      ]
    },
    "js": {
      "include": [
        "**/*.js",
        "**/*.jsx"
      ],
      "exclude": [
        "**/node_modules/**",
        "**/vendor/**",
        "**/dist/**",
        "**/out/**"
      ]
    }
  },
  "chunkers": {
    "md": "@vivantel/virage-chunker-ce-md",
    "ts": "@vivantel/virage-code-chunk-chunker",
    "js": "@vivantel/virage-code-chunk-chunker"
  },
  "databases": {
    "minilm-384-ast": {
      "url": "https://github.com/vivantel/virage/releases/download/eval-db-2026-07-04-2a97856b/minilm-384-ast.tar.gz",
      "description": "all-MiniLM-L6-v2 384d, AST+Markdown chunking, virage master branch",
      "embedder": {
        "package": "@vivantel/virage-embedder-transformers",
        "config": {
          "model": "Xenova/all-MiniLM-L6-v2",
          "dimensions": 384
        }
      },
      "vectorStore": {
        "package": "@vivantel/virage-store-lancedb"
      },
      "sha256": "94061ac75606b4b70610c8843744246218ee4698ea30364e6dca606550619d61",
      "pluginVersions": {
        "@vivantel/virage-agent-antigravity": "0.1.11",
        "@vivantel/virage-agent-claude": "0.2.29",
        "@vivantel/virage-agent-codex": "0.1.11",
        "@vivantel/virage-agent-copilot": "0.1.11",
        "@vivantel/virage-agent-core": "0.1.8",
        "@vivantel/virage-chunker-ce-ast": "0.1.20",
        "@vivantel/virage-chunker-ce-md": "0.1.9",
        "@vivantel/virage-chunker-ce-md-linux-x64-gnu": "0.1.9",
        "@vivantel/virage-cli": "0.3.1",
        "@vivantel/virage-code-chunk-chunker": "0.1.61",
        "@vivantel/virage-core": "0.4.1",
        "@vivantel/virage-embedder-transformers": "0.3.1",
        "@vivantel/virage-reranker-cross-encoder": "0.2.1",
        "@vivantel/virage-skills": "0.1.9",
        "@vivantel/virage-store-lancedb": "0.3.1"
      }
    }
  },
  "variants": [
    {
      "name": "vector",
      "database": "minilm-384-ast",
      "description": "Pure vector search (cosine)"
    },
    {
      "name": "hybrid",
      "database": "minilm-384-ast",
      "description": "Hybrid BM25 + vector via RRF (alpha=0.6)",
      "search": {
        "hybrid": true,
        "hybridAlpha": 0.6
      }
    },
    {
      "name": "vector-ce",
      "database": "minilm-384-ast",
      "description": "Vector search re-ranked by ms-marco cross-encoder",
      "search": {
        "reranker": {
          "package": "@vivantel/virage-reranker-cross-encoder",
          "config": {
            "model": "Xenova/ms-marco-MiniLM-L-6-v2",
            "topK": 5
          }
        }
      }
    },
    {
      "name": "hybrid-ce",
      "database": "minilm-384-ast",
      "description": "Hybrid search re-ranked by ms-marco cross-encoder",
      "search": {
        "hybrid": true,
        "hybridAlpha": 0.6,
        "reranker": {
          "package": "@vivantel/virage-reranker-cross-encoder",
          "config": {
            "model": "Xenova/ms-marco-MiniLM-L-6-v2",
            "topK": 5
          }
        }
      }
    },
    {
      "name": "hybrid-ce-os10",
      "database": "minilm-384-ast",
      "description": "Hybrid + cross-encoder, rerankOversample=10 (100 candidates)",
      "search": {
        "hybrid": true,
        "hybridAlpha": 0.6,
        "rerankOversample": 10,
        "reranker": {
          "package": "@vivantel/virage-reranker-cross-encoder",
          "config": {
            "model": "Xenova/ms-marco-MiniLM-L-6-v2",
            "topK": 5
          }
        }
      }
    },
    {
      "name": "hybrid-ce-os15",
      "database": "minilm-384-ast",
      "description": "Hybrid + cross-encoder, rerankOversample=15 (150 candidates)",
      "search": {
        "hybrid": true,
        "hybridAlpha": 0.6,
        "rerankOversample": 15,
        "reranker": {
          "package": "@vivantel/virage-reranker-cross-encoder",
          "config": {
            "model": "Xenova/ms-marco-MiniLM-L-6-v2",
            "topK": 5
          }
        }
      }
    },
    {
      "name": "hybrid-ce-a030",
      "database": "minilm-384-ast",
      "description": "Hybrid + cross-encoder, hybridAlpha=0.3 (70% BM25, 30% vector)",
      "search": {
        "hybrid": true,
        "hybridAlpha": 0.3,
        "reranker": {
          "package": "@vivantel/virage-reranker-cross-encoder",
          "config": {
            "model": "Xenova/ms-marco-MiniLM-L-6-v2",
            "topK": 5
          }
        }
      }
    },
    {
      "name": "hybrid-ce-a050",
      "database": "minilm-384-ast",
      "description": "Hybrid + cross-encoder, hybridAlpha=0.5 (50/50 blend)",
      "search": {
        "hybrid": true,
        "hybridAlpha": 0.5,
        "reranker": {
          "package": "@vivantel/virage-reranker-cross-encoder",
          "config": {
            "model": "Xenova/ms-marco-MiniLM-L-6-v2",
            "topK": 5
          }
        }
      }
    },
    {
      "name": "hybrid-ce-a070",
      "database": "minilm-384-ast",
      "description": "Hybrid + cross-encoder, hybridAlpha=0.7 (70% vector, 30% BM25)",
      "search": {
        "hybrid": true,
        "hybridAlpha": 0.7,
        "reranker": {
          "package": "@vivantel/virage-reranker-cross-encoder",
          "config": {
            "model": "Xenova/ms-marco-MiniLM-L-6-v2",
            "topK": 5
          }
        }
      }
    },
    {
      "name": "hybrid-ce-ms01",
      "database": "minilm-384-ast",
      "description": "Hybrid + cross-encoder, minScore=0.1 (filter low-confidence), oversample=10",
      "search": {
        "hybrid": true,
        "hybridAlpha": 0.6,
        "rerankOversample": 10,
        "reranker": {
          "package": "@vivantel/virage-reranker-cross-encoder",
          "config": {
            "model": "Xenova/ms-marco-MiniLM-L-6-v2",
            "topK": 5,
            "minScore": 0.1
          }
        }
      }
    },
    {
      "name": "hybrid-ce-ms03",
      "database": "minilm-384-ast",
      "description": "Hybrid + cross-encoder, minScore=0.3 (aggressive filter), oversample=10",
      "search": {
        "hybrid": true,
        "hybridAlpha": 0.6,
        "rerankOversample": 10,
        "reranker": {
          "package": "@vivantel/virage-reranker-cross-encoder",
          "config": {
            "model": "Xenova/ms-marco-MiniLM-L-6-v2",
            "topK": 5,
            "minScore": 0.3
          }
        }
      }
    }
  ]
}
