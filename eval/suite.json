{
  "version": "1",
  "dataset": "golden-dataset.json",
  "topK": 10,
  "baseline": "vector",
  "ciGate": { "mrr": 0.35 },
  "cacheDir": "../.virage/eval-cache",
  "exclude": [
    "**/*.a",
    "**/*.class",
    "**/*.generated.cs",
    "**/*.lock",
    "**/*.min.css",
    "**/*.min.js",
    "**/*.o",
    "**/*.pb.cs",
    "**/*.pb.go",
    "**/*.pb.ts",
    "**/.next/**",
    "**/.turbo/**",
    "**/CMakeFiles/**",
    "**/bin/**",
    "**/cmake-build-*/**",
    "**/package-lock.json",
    "**/pnpm-lock.yaml",
    "**/target/**",
    "**/yarn.lock"
  ],
  "filesets": {
    "md": {
      "include": ["**/*.md", "**/*.mdx"],
      "exclude": ["**/node_modules/**", "**/vendor/**", "**/dist/**", "**/out/**", "CHANGELOG.md"]
    },
    "ts": {
      "include": ["**/*.ts", "**/*.tsx"],
      "exclude": ["**/node_modules/**", "**/vendor/**", "**/dist/**", "**/out/**", "**/*.d.ts"]
    },
    "js": {
      "include": ["**/*.js", "**/*.jsx"],
      "exclude": ["**/node_modules/**", "**/vendor/**", "**/dist/**", "**/out/**"]
    }
  },
  "chunkers": {
    "md": "markdownHeaders",
    "ts": "codeChunkAst",
    "js": "codeChunkAst"
  },
  "databases": {
    "minilm-384-ast": {
      "url": "https://github.com/vivantel/virage/releases/download/eval-db/minilm-384-ast.tar.gz",
      "description": "all-MiniLM-L6-v2 384d, AST+Markdown chunking, virage master branch",
      "embedder": {
        "package": "@vivantel/virage-embedder-transformers",
        "config": { "model": "Xenova/all-MiniLM-L6-v2", "dimensions": 384 }
      },
      "vectorStore": {
        "package": "@vivantel/virage-store-lancedb"
      }
    }
  },
  "variants": [
    {
      "name": "vector",
      "database": "minilm-384-ast",
      "description": "Pure vector search (cosine)"
    },
    {
      "name": "hybrid",
      "database": "minilm-384-ast",
      "description": "Hybrid BM25 + vector via RRF (alpha=0.6)",
      "search": { "hybrid": true, "hybridAlpha": 0.6 }
    },
    {
      "name": "vector-cross-encoder",
      "database": "minilm-384-ast",
      "description": "Vector search re-ranked by ms-marco cross-encoder",
      "search": {
        "reranker": {
          "package": "@vivantel/virage-reranker-cross-encoder",
          "config": { "model": "Xenova/ms-marco-MiniLM-L-6-v2", "topK": 5 }
        }
      }
    },
    {
      "name": "hybrid-cross-encoder",
      "database": "minilm-384-ast",
      "description": "Hybrid search re-ranked by ms-marco cross-encoder",
      "search": {
        "hybrid": true,
        "hybridAlpha": 0.6,
        "reranker": {
          "package": "@vivantel/virage-reranker-cross-encoder",
          "config": { "model": "Xenova/ms-marco-MiniLM-L-6-v2", "topK": 5 }
        }
      }
    }
  ]
}
