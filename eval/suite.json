{
  "version": "1",
  "dataset": "golden-dataset.json",
  "topK": 10,
  "baseline": "vector",
  "ciGate": {
    "mrr": 0.35
  },
  "cacheDir": "../.virage/eval-cache",
  "exclude": [
    "**/*.a",
    "**/*.class",
    "**/*.generated.cs",
    "**/*.lock",
    "**/*.min.css",
    "**/*.min.js",
    "**/*.o",
    "**/*.pb.cs",
    "**/*.pb.go",
    "**/*.pb.ts",
    "**/.next/**",
    "**/.turbo/**",
    "**/CMakeFiles/**",
    "**/bin/**",
    "**/cmake-build-*/**",
    "**/package-lock.json",
    "**/pnpm-lock.yaml",
    "**/target/**",
    "**/yarn.lock"
  ],
  "filesets": {
    "md": {
      "include": [
        "**/*.md",
        "**/*.mdx"
      ],
      "exclude": [
        "**/node_modules/**",
        "**/vendor/**",
        "**/dist/**",
        "**/out/**",
        "CHANGELOG.md"
      ]
    },
    "ts": {
      "include": [
        "**/*.ts",
        "**/*.tsx"
      ],
      "exclude": [
        "**/node_modules/**",
        "**/vendor/**",
        "**/dist/**",
        "**/out/**",
        "**/*.d.ts"
      ]
    },
    "js": {
      "include": [
        "**/*.js",
        "**/*.jsx"
      ],
      "exclude": [
        "**/node_modules/**",
        "**/vendor/**",
        "**/dist/**",
        "**/out/**"
      ]
    }
  },
  "chunkers": {
    "md": "markdownHeaders",
    "ts": "codeChunkAst",
    "js": "codeChunkAst"
  },
  "databases": {
    "minilm-384-ast": {
      "url": "https://github.com/vivantel/virage/releases/download/eval-db-2026-06-24-1e9f5e7/minilm-384-ast.tar.gz",
      "description": "all-MiniLM-L6-v2 384d, AST+Markdown chunking, virage master branch",
      "embedder": {
        "package": "@vivantel/virage-embedder-transformers",
        "config": {
          "model": "Xenova/all-MiniLM-L6-v2",
          "dimensions": 384
        }
      },
      "vectorStore": {
        "package": "@vivantel/virage-store-lancedb"
      },
      "sha256": "f8b63c51e7285d0e0edfe6c17704c24f0ebb0aa5059c68e5ddd21ecf908a720e",
      "pluginVersions": {
        "@vivantel/virage-agent-claude": "0.2.26",
        "@vivantel/virage-agent-core": "0.1.7",
        "@vivantel/virage-cli": "0.1.88",
        "@vivantel/virage-code-chunk-chunker": "0.1.41",
        "@vivantel/virage-core": "0.2.56",
        "@vivantel/virage-embedder-transformers": "0.2.58",
        "@vivantel/virage-reranker-cross-encoder": "0.1.33",
        "@vivantel/virage-skills": "0.1.9",
        "@vivantel/virage-store-lancedb": "0.2.59"
      }
    }
  },
  "variants": [
    {
      "name": "vector",
      "database": "minilm-384-ast",
      "description": "Pure vector search (cosine)"
    },
    {
      "name": "hybrid",
      "database": "minilm-384-ast",
      "description": "Hybrid BM25 + vector via RRF (alpha=0.6)",
      "search": {
        "hybrid": true,
        "hybridAlpha": 0.6
      }
    },
    {
      "name": "vector-ce",
      "database": "minilm-384-ast",
      "description": "Vector search re-ranked by ms-marco cross-encoder",
      "search": {
        "reranker": {
          "package": "@vivantel/virage-reranker-cross-encoder",
          "config": {
            "model": "Xenova/ms-marco-MiniLM-L-6-v2",
            "topK": 5
          }
        }
      }
    },
    {
      "name": "hybrid-ce",
      "database": "minilm-384-ast",
      "description": "Hybrid search re-ranked by ms-marco cross-encoder",
      "search": {
        "hybrid": true,
        "hybridAlpha": 0.6,
        "reranker": {
          "package": "@vivantel/virage-reranker-cross-encoder",
          "config": {
            "model": "Xenova/ms-marco-MiniLM-L-6-v2",
            "topK": 5
          }
        }
      }
    },
    {
      "name": "hybrid-ce-os10",
      "database": "minilm-384-ast",
      "description": "Hybrid + cross-encoder, rerankOversample=10 (100 candidates)",
      "search": {
        "hybrid": true,
        "hybridAlpha": 0.6,
        "rerankOversample": 10,
        "reranker": {
          "package": "@vivantel/virage-reranker-cross-encoder",
          "config": {
            "model": "Xenova/ms-marco-MiniLM-L-6-v2",
            "topK": 5
          }
        }
      }
    },
    {
      "name": "hybrid-ce-os15",
      "database": "minilm-384-ast",
      "description": "Hybrid + cross-encoder, rerankOversample=15 (150 candidates)",
      "search": {
        "hybrid": true,
        "hybridAlpha": 0.6,
        "rerankOversample": 15,
        "reranker": {
          "package": "@vivantel/virage-reranker-cross-encoder",
          "config": {
            "model": "Xenova/ms-marco-MiniLM-L-6-v2",
            "topK": 5
          }
        }
      }
    },
    {
      "name": "hybrid-ce-a030",
      "database": "minilm-384-ast",
      "description": "Hybrid + cross-encoder, hybridAlpha=0.3 (70% BM25, 30% vector)",
      "search": {
        "hybrid": true,
        "hybridAlpha": 0.3,
        "reranker": {
          "package": "@vivantel/virage-reranker-cross-encoder",
          "config": {
            "model": "Xenova/ms-marco-MiniLM-L-6-v2",
            "topK": 5
          }
        }
      }
    },
    {
      "name": "hybrid-ce-a050",
      "database": "minilm-384-ast",
      "description": "Hybrid + cross-encoder, hybridAlpha=0.5 (50/50 blend)",
      "search": {
        "hybrid": true,
        "hybridAlpha": 0.5,
        "reranker": {
          "package": "@vivantel/virage-reranker-cross-encoder",
          "config": {
            "model": "Xenova/ms-marco-MiniLM-L-6-v2",
            "topK": 5
          }
        }
      }
    },
    {
      "name": "hybrid-ce-a070",
      "database": "minilm-384-ast",
      "description": "Hybrid + cross-encoder, hybridAlpha=0.7 (70% vector, 30% BM25)",
      "search": {
        "hybrid": true,
        "hybridAlpha": 0.7,
        "reranker": {
          "package": "@vivantel/virage-reranker-cross-encoder",
          "config": {
            "model": "Xenova/ms-marco-MiniLM-L-6-v2",
            "topK": 5
          }
        }
      }
    },
    {
      "name": "hybrid-ce-ms01",
      "database": "minilm-384-ast",
      "description": "Hybrid + cross-encoder, minScore=0.1 (filter low-confidence), oversample=10",
      "search": {
        "hybrid": true,
        "hybridAlpha": 0.6,
        "rerankOversample": 10,
        "reranker": {
          "package": "@vivantel/virage-reranker-cross-encoder",
          "config": {
            "model": "Xenova/ms-marco-MiniLM-L-6-v2",
            "topK": 5,
            "minScore": 0.1
          }
        }
      }
    },
    {
      "name": "hybrid-ce-ms03",
      "database": "minilm-384-ast",
      "description": "Hybrid + cross-encoder, minScore=0.3 (aggressive filter), oversample=10",
      "search": {
        "hybrid": true,
        "hybridAlpha": 0.6,
        "rerankOversample": 10,
        "reranker": {
          "package": "@vivantel/virage-reranker-cross-encoder",
          "config": {
            "model": "Xenova/ms-marco-MiniLM-L-6-v2",
            "topK": 5,
            "minScore": 0.3
          }
        }
      }
    }
  ]
}
