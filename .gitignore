# Dependencies
node_modules

# Build output
dist/
build/
*.tsbuildinfo

# Generated documentation
docs/api/

# RAG pipeline artifacts (cached in CI via actions/cache)
.virage/

# Internal docs
docs/internal

# Consumer-generated Virage config (generated by virage init; keep virage.config.ci.json tracked)
virage.config.json
virage.config.json.bak.*

# Environment files
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Test coverage
coverage/
.nyc_output/

# Test artifacts
test-embeddings.db
test-*.json
npm-audit*.json
npm-outdated*.json
*.tgz
packages/virage-dashboard/test-results/

# Logs
logs/
*.log
npm-debug.log*
/.npmrc

# Experiment runs
.rag-experiments/

# Per-package lock files generated by running npm inside a workspace package
# (root package-lock.json is canonical for this monorepo)
packages/*/package-lock.json

# Plugin-generated skill installs (regenerated by `virage update` / plugin configure)
# Source of truth: packages/virage-skills/skills/ and plugin-config/commands/
.agents/skills/virage/
.claude/skills/
