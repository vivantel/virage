{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "npm run fix && npm run type-check && git add -u || exit 2",
            "statusMessage": "Running fix + type-check before commit..."
          }
        ]
      }
    ]
  }
}
