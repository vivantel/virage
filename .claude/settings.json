{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "cd /home/ubuntu/data/projects/vivantel/rag_core && npm run fix 2>&1 || true",
            "statusMessage": "Running lint:fix + format before commit..."
          }
        ]
      }
    ]
  }
}
