{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(*git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "npm run fix && npm run type-check:ci && git add -u",
            "statusMessage": "Running fix + type-check before commit..."
          }
        ]
      }
    ]
  }
}
