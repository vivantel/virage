{
  "name": "vivantel-virage-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "description": "Monorepo for @vivantel/virage-core and related packages",
  "scripts": {
    "build:all": "npm run build -w packages/virage-core && npm run build -w packages/virage-agent-core && npm run build --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "type-check:ci": "npm run type-check -w packages/virage-core -w packages/virage-cli -w packages/virage-store-postgres -w packages/virage-store-qdrant -w packages/virage-store-chromadb -w packages/virage-embedder-fastembed -w packages/virage-code-chunk-chunker -w packages/virage-agent-core -w packages/virage-agent-copilot -w packages/virage-agent-codex -w packages/virage-agent-antigravity -w packages/virage-agent-claude",
    "lint": "eslint \"packages/*/src/**/*.ts\" \"packages/*/src-ts/**/*.ts\"",
    "lint:fix": "eslint \"packages/*/src/**/*.ts\" \"packages/*/src-ts/**/*.ts\" --fix",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\" \"packages/*/src-ts/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx}\" \"packages/*/src-ts/**/*.{ts,tsx}\"",
    "fix": "npm run lint:fix && npm run format",
    "rust:fmt": "cargo fmt",
    "rust:lint": "cargo clippy --workspace -- -D warnings",
    "rust:fix": "cargo fmt && cargo clippy --workspace -- -D warnings",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules coverage",
    "prepare": "git config core.hooksPath .githooks || true",
    "postinstall": "node scripts/patch-lockfile-stubs.cjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@napi-rs/cli": "^3.7.2",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "version": "0.1.0",
  "dependencies": {
    "@vivantel/virage-agent-claude": "^0.2.24",
    "@vivantel/virage-chunker-ce-ast": "^0.1.25",
    "@vivantel/virage-chunker-ce-md": "^0.1.10",
    "@vivantel/virage-code-chunk-chunker": "^0.1.16",
    "@vivantel/virage-core": "^0.2.31",
    "@vivantel/virage-embedder-transformers": "^0.2.33",
    "@vivantel/virage-skills": "^0.1.8",
    "@vivantel/virage-store-lancedb": "^0.2.33",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
