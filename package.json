{
  "name": "vivantel-rag-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "description": "Monorepo for @vivantel/rag-core and related packages",
  "scripts": {
    "build:all": "npm run build --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "type-check:ci": "npm run type-check -w packages/rag-core -w packages/rag-strategies -w packages/rag-store-postgres -w packages/rag-store-qdrant -w packages/rag-store-lancedb -w packages/rag-store-chromadb -w packages/rag-embedder-fastembed",
    "lint": "eslint packages/rag-core/src/ packages/*/src/",
    "lint:fix": "eslint packages/rag-core/src/ packages/*/src/ --fix",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "format:check": "prettier --check \"packages/*/src/**/*.ts\"",
    "fix": "npm run lint:fix && npm run format",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules coverage"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "version": "3.0.0"
}
